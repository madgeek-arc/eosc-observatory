<!DOCTYPE html>
<html>

<head>
    <title>EOSC Observatory - Mention Notification</title>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <style type="text/css">
        @media screen {
            @font-face {
                font-family: 'Lato';
                font-style: normal;
                font-weight: 400;
                src: local('Lato Regular'), local('Lato-Regular'), url(https://fonts.gstatic.com/s/lato/v11/qIIYRU-oROkIk8vfvxw6QvesZW2xOQ-xsNqO47m55DA.woff) format('woff');
            }
            @font-face {
                font-family: 'Lato';
                font-style: normal;
                font-weight: 700;
                src: local('Lato Bold'), local('Lato-Bold'), url(https://fonts.gstatic.com/s/lato/v11/qdgUG4U09HnJwhYI-uK18wLUuEpTyoUstqEm5AMlJo4.woff) format('woff');
            }
            @font-face {
                font-family: 'Lato';
                font-style: italic;
                font-weight: 400;
                src: local('Lato Italic'), local('Lato-Italic'), url(https://fonts.gstatic.com/s/lato/v11/RYyZNoeFgb0l7W3Vu1aSWOvvDin1pK8aKteLpeZ5c0A.woff) format('woff');
            }
            @font-face {
                font-family: 'Lato';
                font-style: italic;
                font-weight: 700;
                src: local('Lato Bold Italic'), local('Lato-BoldItalic'), url(https://fonts.gstatic.com/s/lato/v11/HkF_qI1x_noxlxhrhMQYELO3LdcAZYWl9Si6vvxL-qU.woff) format('woff');
            }
        }
        @media screen and (max-width: 600px) {
            .body-padding { padding-left: 15px !important; padding-right: 15px !important; }
            .headline-text { font-size: 15px !important; line-height: 22px !important; }
            .signoff-text { font-size: 15px !important; line-height: 22px !important; }
            .cta-button { padding: 12px 20px !important; font-size: 15px !important; }
            .footer-cell { font-size: 15px !important; }
        }
    </style>
</head>

<body style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; background-color: #f4f4f4; height: 100%; width: 100%; margin: 0; padding: 0;">

<!-- PREHEADER -->
<#--<div style="display: none; font-size: 1px; color: #fefefe; line-height: 1px; font-family: 'Lato', Helvetica, Arial, sans-serif; max-height: 0px; max-width: 0px; opacity: 0; overflow: hidden;">-->
<#--    ${from.fullname} mentioned you in a comment on EOSC Observatory.-->
<#--</div>-->

<table border="0" cellpadding="0" cellspacing="0" width="100%"
       style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-collapse: collapse;">

    <!-- LOGO -->
    <tr>
        <td bgcolor="#008792" align="center"
            style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 40px 10px 0px 10px;">
            <table border="0" cellpadding="0" cellspacing="0" width="100%"
                   style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; max-width: 600px; border-collapse: collapse;">
                <tr>
                    <td bgcolor="#ffffff" align="center" valign="top"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 40px 20px 20px 20px; border-radius: 4px 4px 0px 0px; font-family: 'Lato', Helvetica, Arial, sans-serif;">
                        <img alt="EOSC Observatory"
                             src="https://eoscobservatory.eosc-portal.eu/assets/logo/png/EOSC OPEN SCIENCE OBSERVATORY LOGO.png"
                             width="300"  style="display: block; border: 0; margin: 0 auto;"/>
                    </td>
                </tr>
            </table>
        </td>
    </tr>

    <!-- BODY -->
    <tr>
        <td bgcolor="#f4f4f4" align="center"
            style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 0px 10px 0px 10px;">
            <table border="0" cellpadding="0" cellspacing="0" width="100%"
                   style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; max-width: 600px; border-collapse: collapse;">

                <!-- GREETING -->
                <tr>
                    <td bgcolor="#ffffff" align="left" class="body-padding"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 25px 30px 0px 30px; color: #555555; font-family: 'Lato', Helvetica, Arial, sans-serif; font-size: 16px; font-weight: 400; line-height: 24px;">
                        <p style="margin: 0;">Hello <b>${to.name}</b>,</p>
                    </td>
                </tr>

                <!-- HEADLINE -->
                <tr>
                    <td bgcolor="#ffffff" align="left" class="body-padding headline-text"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 10px 30px 10px 30px; color: #1a1a1a; font-family: 'Lato', Helvetica, Arial, sans-serif; font-size: 18px; font-weight: 400; line-height: 25px;">
                        <p style="margin: 0;">
                            <b>${from.name}</b> (${from.email}) mentioned you in a comment in the
                            following section of the Survey of National Contributions to EOSC and Open Science 2024
                        </p>
                    </td>
                </tr>


                <tr>
                    <td bgcolor="#ffffff" align="left" class="body-padding"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 15px 30px 20px 30px; font-family: 'Lato', Helvetica, Arial, sans-serif;">
                        <table border="0" cellpadding="0" cellspacing="0"
                               style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-collapse: collapse;">
                            <tr>
                                <td style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; background-color: #e8f4f5; border-radius: 4px; padding: 8px 16px; font-family: 'Lato', Helvetica, Arial, sans-serif; font-size: 15px; font-weight: 700; color: #008792;">
                                    ${chapter.name}
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- DIVIDER -->
                <tr>
                    <td bgcolor="#ffffff" class="body-padding"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 0 30px;">
                        <table border="0" cellpadding="0" cellspacing="0" width="100%"
                               style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-collapse: collapse;">
                            <tr>
                                <td style="border-top: 1px solid #eeeeee; font-size: 0; line-height: 0;">&nbsp;</td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- COMMENT BOX -->
                <tr>
                    <td bgcolor="#ffffff" align="left" class="body-padding"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 20px 30px 10px 30px; font-family: 'Lato', Helvetica, Arial, sans-serif;">
                        <table border="0" cellpadding="0" cellspacing="0" width="100%"
                               style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; border: 1px solid #e0e0e0; border-radius: 4px; border-collapse: collapse;">
                            <tr>
                                <td width="4" bgcolor="#008792"
                                    style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-radius: 4px 0 0 4px;">&nbsp;</td>
                                <td style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 16px 20px; font-family: 'Lato', Helvetica, Arial, sans-serif; font-size: 16px; font-weight: 400; color: #333333; line-height: 24px;">
                                    ${body}
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- SENDER + TIMESTAMP -->
                <tr>
                    <td bgcolor="#ffffff" align="left" class="body-padding"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 10px 30px 25px 54px; font-family: 'Lato', Helvetica, Arial, sans-serif; font-size: 14px; color: #888888; line-height: 20px;">
                        <b>${from.name}</b> &nbsp;&bull;&nbsp; ${date}
                    </td>
                </tr>

                <!-- DIVIDER -->
                <tr>
                    <td bgcolor="#ffffff" class="body-padding"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 0 30px;">
                        <table border="0" cellpadding="0" cellspacing="0" width="100%"
                               style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-collapse: collapse;">
                            <tr>
                                <td style="border-top: 1px solid #eeeeee; font-size: 0; line-height: 0;">&nbsp;</td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- CTA BUTTON -->
                <tr>
                    <td bgcolor="#ffffff" align="center"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 25px 30px 15px 30px;">
                        <table border="0" cellspacing="0" cellpadding="0"
                               style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-collapse: collapse;">
                            <tr>
                                <td align="center" bgcolor="#008792"
                                    style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; border-radius: 3px;">
                                    <a href="${baseUrl}/contributions/${stakeholderId}/mySurveys/${surveyId}/answer/view"
                                       target="_blank" class="cta-button"
                                       style="font-size: 16px; font-family: 'Lato', Helvetica, Arial, sans-serif; color: #ffffff; text-decoration: none; padding: 14px 30px; border-radius: 3px; border: 1px solid #008792; display: inline-block; font-weight: 700;">
                                        Go to survey &rarr;
                                    </a>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <!-- SIGN OFF -->
                <tr>
                    <td bgcolor="#ffffff" align="left" class="body-padding signoff-text"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 15px 30px 40px 30px; border-radius: 0px 0px 4px 4px; color: #1a1a1a; font-family: 'Lato', Helvetica, Arial, sans-serif; font-size: 18px; font-weight: 400; line-height: 25px;">
                        <p style="margin: 0;">Kind regards,<br>The EOSC Observatory Team</p>
                    </td>
                </tr>

            </table>
        </td>
    </tr>

    <!-- FOOTER -->
    <tr>
        <td bgcolor="#f4f4f4" align="center"
            style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 30px 10px 0px 10px;">
            <table border="0" cellpadding="0" cellspacing="0" width="100%"
                   style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; max-width: 600px; border-collapse: collapse;">
                <tr>
                    <td align="center" class="footer-cell" bgcolor="#d4eef0"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 30px 30px 30px 30px; border-radius: 4px; color: #666666; font-family: 'Lato', Helvetica, Arial, sans-serif; font-size: 18px; font-weight: 400; line-height: 25px; background-color: #d4eef0;">
                        <h2 style="font-size: 20px; font-weight: 400; color: #111111; margin: 0;">Need more help?</h2>
                        <p style="margin: 0;">
                            <a href="mailto:stefania.martziou@openaire.eu" target="_blank"
                               style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; color: #008792;">Contact us</a>
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>

    <!-- FINE PRINT -->
    <tr>
        <td bgcolor="#f4f4f4" align="center"
            style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 20px 10px 30px 10px;">
            <table border="0" cellpadding="0" cellspacing="0" width="100%"
                   style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; max-width: 600px; border-collapse: collapse;">
                <tr>
                    <td align="center"
                        style="-webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; mso-table-lspace: 0pt; mso-table-rspace: 0pt; padding: 0 30px; font-family: 'Lato', Helvetica, Arial, sans-serif; font-size: 13px; color: #999999; line-height: 20px;">
                        <p style="margin: 0;">
                            You received this notification because you were mentioned in this thread by
                            ${from.name} (${from.email}).
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>

</table>
</body>
</html>
